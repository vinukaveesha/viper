// Pipeline example: code review on PR. Set SCM_* and LLM_* via parameters or Gitea webhook.
// Agent runs as one-shot container: <runtime> run --rm code-review-agent review
//   OR inline (USE_INLINE_AGENT=true): code-review --owner ... --repo ... --pr ... --head-sha ... (no Docker required; see docs/JENKINS-NO-DOCKER.md).
// Build agent image from repo root: docker build -t code-review-agent -f docker/Dockerfile.agent .
// Runtime: set CONTAINER_RUNTIME (e.g. podman) to force one; otherwise pipeline auto-detects docker or podman.
//
// Required Jenkins Secret text credentials:
//   - ID "SCM_TOKEN": SCM access token for commenting on PRs.
//   - ID "GOOGLE_API_KEY": LLM API key (or equivalent provider key when using Gemini).
// If your organisation uses different credential IDs, update the `environment {}` block
// below to match your Jenkins credentials naming convention.

pipeline {
    agent any

    environment {
        // Credentials IDs must exist in Jenkins (Secret text).
        SCM_TOKEN = credentials('SCM_TOKEN')
        GOOGLE_API_KEY = credentials('GOOGLE_API_KEY')
    }

    parameters {
        string(name: 'SCM_OWNER', description: 'Repo owner')
        string(name: 'SCM_REPO', description: 'Repo name')
        string(name: 'SCM_PR_NUM', description: 'PR number')
        string(name: 'SCM_HEAD_SHA', description: 'Head commit SHA')
        string(name: 'PR_ACTION', description: 'Pull request webhook action')
        string(name: 'LLM_PROVIDER', defaultValue: 'gemini', description: 'LLM provider')
        string(name: 'LLM_MODEL', defaultValue: 'gemini-2.5-flash', description: 'LLM model')
        string(name: 'COMPOSE_PROJECT_NAME', defaultValue: 'code-review', description: 'Docker Compose project name for agent network; set env COMPOSE_PROJECT_NAME or use -p when starting compose')
    }

    stages {
        stage('Code Review') {
            steps {
                script {
                    def image = 'code-review-agent'
                    def projectName = env.COMPOSE_PROJECT_NAME ?: params.COMPOSE_PROJECT_NAME
                    def network = "${projectName}_code-review-net"
                    def scmOwner = params.SCM_OWNER ?: env.SCM_OWNER
                    def scmRepo = params.SCM_REPO ?: env.SCM_REPO
                    def scmPrNum = params.SCM_PR_NUM ?: env.SCM_PR_NUM
                    def scmHeadSha = params.SCM_HEAD_SHA ?: env.SCM_HEAD_SHA
                    def prAction = params.PR_ACTION ?: env.PR_ACTION
                    def llmProvider = params.LLM_PROVIDER ?: env.LLM_PROVIDER
                    def llmModel = params.LLM_MODEL ?: env.LLM_MODEL
                    def containerRuntime = env.CONTAINER_RUNTIME ?: 'docker'
                    // Supported webhook actions:
                    // - GitHub / Gitea style: "opened", "synchronize"
                    // - Bitbucket Data Center "eventKey": "pr:opened", "pr:modified", "pr:from_ref_updated"
                    def allowedActions = ['opened', 'synchronize', 'pr:opened', 'pr:modified', 'pr:from_ref_updated']

                    if (!env.SCM_TOKEN?.trim()) {
                        error('SCM_TOKEN is empty. Configure Jenkins Secret text credentials with ID "SCM_TOKEN" (see README.md) before running this pipeline.')
                    }

                    if (prAction && !allowedActions.contains(prAction)) {
                        currentBuild.description = "Skipped PR action: ${prAction}"
                        echo "Skipping PR action '${prAction}'. Allowed actions: ${allowedActions.join(', ')}."
                        return
                    }

                    if (!scmOwner || scmOwner.contains('$.pull_request')) {
                        error('SCM_OWNER not resolved from webhook. Check Generic Webhook Trigger JSONPath mapping.')
                    }
                    if (!scmRepo || scmRepo.contains('$.pull_request')) {
                        error('SCM_REPO not resolved from webhook. Check Generic Webhook Trigger JSONPath mapping.')
                    }
                    if (!scmPrNum || scmPrNum.contains('$.pull_request')) {
                        error('SCM_PR_NUM not resolved from webhook. Check Generic Webhook Trigger JSONPath mapping.')
                    }
                    if (!scmHeadSha || scmHeadSha.contains('$.pull_request')) {
                        error('SCM_HEAD_SHA not resolved from webhook. Check Generic Webhook Trigger JSONPath mapping.')
                    }
                    // SCM_TOKEN and GOOGLE_API_KEY are injected via Jenkins credentials (environment {} above).
                    def useInlineAgent = env.USE_INLINE_AGENT == 'true' || env.USE_INLINE_AGENT == '1'
                    def scmProvider = env.SCM_PROVIDER ?: 'gitea'
                    def scmUrl = env.SCM_URL ?: 'http://gitea:3000'
                    withEnv([
                        "CONTAINER_RUNTIME=${containerRuntime}",
                        "REVIEW_IMAGE=${image}",
                        "REVIEW_NETWORK=${network}",
                        "REVIEW_SCM_OWNER=${scmOwner}",
                        "REVIEW_SCM_REPO=${scmRepo}",
                        "REVIEW_SCM_PR_NUM=${scmPrNum}",
                        "REVIEW_SCM_HEAD_SHA=${scmHeadSha}",
                        "REVIEW_SCM_PROVIDER=${scmProvider}",
                        "REVIEW_SCM_URL=${scmUrl}",
                        "REVIEW_LLM_PROVIDER=${llmProvider}",
                        "REVIEW_LLM_MODEL=${llmModel}",
                        "USE_INLINE_AGENT=${useInlineAgent}",
                    ]) {
                        sh '''
                            set -euo pipefail
                            if [ "$USE_INLINE_AGENT" = "true" ] || [ "$USE_INLINE_AGENT" = "1" ]; then
                                export SCM_PROVIDER="$REVIEW_SCM_PROVIDER" SCM_URL="$REVIEW_SCM_URL" SCM_TOKEN="$SCM_TOKEN"
                                export LLM_PROVIDER="$REVIEW_LLM_PROVIDER" LLM_MODEL="$REVIEW_LLM_MODEL"
                                code-review --owner "$REVIEW_SCM_OWNER" --repo "$REVIEW_SCM_REPO" --pr "$REVIEW_SCM_PR_NUM" --head-sha "$REVIEW_SCM_HEAD_SHA" --print-findings
                            else
                                runtime="$CONTAINER_RUNTIME"
                                if [ -z "$runtime" ] || ! command -v "$runtime" >/dev/null 2>&1; then
                                    if command -v docker >/dev/null 2>&1; then
                                        runtime=docker
                                    elif command -v podman >/dev/null 2>&1; then
                                        runtime=podman
                                    else
                                        echo "ERROR: No container runtime found. Set CONTAINER_RUNTIME (e.g. podman) or USE_INLINE_AGENT=true (see docs/QUICKSTART.md)."
                                        exit 1
                                    fi
                                fi
                                "$runtime" run --rm --network "$REVIEW_NETWORK" \
                                    -e SCM_PROVIDER=gitea \
                                    -e SCM_URL=http://gitea:3000 \
                                    -e SCM_TOKEN="$SCM_TOKEN" \
                                    -e SCM_OWNER="$REVIEW_SCM_OWNER" \
                                    -e SCM_REPO="$REVIEW_SCM_REPO" \
                                    -e SCM_PR_NUM="$REVIEW_SCM_PR_NUM" \
                                    -e SCM_HEAD_SHA="$REVIEW_SCM_HEAD_SHA" \
                                    -e LLM_PROVIDER="$REVIEW_LLM_PROVIDER" \
                                    -e LLM_MODEL="$REVIEW_LLM_MODEL" \
                                    -e PYTHONUNBUFFERED=1 \
                                    -e GOOGLE_API_KEY \
                                    "$REVIEW_IMAGE" --owner "$REVIEW_SCM_OWNER" --repo "$REVIEW_SCM_REPO" --pr "$REVIEW_SCM_PR_NUM" --head-sha "$REVIEW_SCM_HEAD_SHA" --print-findings \
                                || { echo "HINT: If using Podman and you see uid_map or 'Operation not permitted', set USE_INLINE_AGENT=true (see docs/QUICKSTART.md)."; exit 1; }
                            fi
                        '''
                    }
                }
            }
        }
    }
}
