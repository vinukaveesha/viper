# Code review agent image: run as one-shot job (e.g. from Jenkins).
# Build: docker build -t code-review-agent -f docker/Dockerfile.agent .
# Run:  docker run --rm -e SCM_* -e LLM_* code-review-agent review --owner O --repo R --pr N --head-sha SHA

FROM python:3.12-slim

WORKDIR /app

# Install deps and package (no dev deps)
# Copy dependency metadata first (changes less often than source)
COPY pyproject.toml ./

# Copy source code (changes frequently)
COPY src ./src/

# Upgrade pip to a version without the known CVEs, then install the package
# and dependencies; pip will reuse wheels between layers when possible. Also
# create an unprivileged user in the same layer to reduce image layers.
RUN python -m pip install --no-cache-dir --upgrade "pip>=26.0" \
    && pip install --no-cache-dir -e . \
    && adduser --disabled-password --gecos "" --uid 1000 appuser \
    && chown -R appuser:appuser /app
USER appuser

# No long-running process; Jenkins (or other CI) invokes: code-review
ENTRYPOINT ["code-review"]
CMD ["review"]
