# Code review agent image: run as one-shot job (e.g. from Jenkins).
# Build: docker build -t code-review-agent -f docker/Dockerfile.agent .
# Run:  docker run --rm -e SCM_* -e LLM_* code-review-agent review --owner O --repo R --pr N --head-sha SHA

FROM python:3.12-slim

WORKDIR /app

# Install third-party deps first so source changes do not invalidate them.
COPY pyproject.toml ./
COPY requirements/runtime.txt ./requirements/runtime.txt

# Upgrade OS packages to pick up security patches (dpkg, glibc, libsqlite3, etc.),
# then upgrade pip and install runtime dependencies. Combining into one layer
# minimises image size and ensures apt lists are not cached.
RUN apt-get update \
    && apt-get upgrade -y --no-install-recommends \
    && rm -rf /var/lib/apt/lists/* \
    && python -m pip install --no-cache-dir --upgrade "pip>=26.0" \
    && pip install --no-cache-dir -r requirements/runtime.txt \
    && adduser --disabled-password --gecos "" --uid 1000 appuser

# Copy source code after dependency installation so application-only changes
# reuse the expensive dependency layer.
COPY README.md ./
COPY src ./src/

RUN pip install --no-cache-dir --no-deps -e . \
    && chown -R appuser:appuser /app
USER appuser

# No long-running process; Jenkins (or other CI) invokes: code-review
ENTRYPOINT ["code-review"]
CMD ["review"]
