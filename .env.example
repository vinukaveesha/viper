# SCM (Gitea, GitLab, Bitbucket)
SCM_PROVIDER=gitea
SCM_URL=http://localhost:3000
SCM_TOKEN=your_api_token_here
# Optional: skip review when PR has this label or title contains this substring
# SCM_SKIP_LABEL=skip-review
# SCM_SKIP_TITLE_PATTERN=[skip-review]

# LLM
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
LLM_CONTEXT_WINDOW=128000
LLM_MAX_OUTPUT_TOKENS=4096

# Provider-specific API keys
GOOGLE_API_KEY=your_google_api_key
# OPENAI_API_KEY=...
# ANTHROPIC_API_KEY=...
# OLLAMA_API_BASE=http://localhost:11434
