# Full list of environment variables: docs/CONFIGURATION-REFERENCE.md
#
# Log level for the CLI: DEBUG, INFO, WARNING (default), ERROR. Set INFO to see progress.
# CODE_REVIEW_LOG_LEVEL=INFO

# SCM (Gitea, GitLab, Bitbucket)
SCM_PROVIDER=gitea
SCM_URL=http://localhost:3000
SCM_TOKEN=your_api_token_here
# Optional: skip review when PR has this label or title contains this substring
# SCM_SKIP_LABEL=skip-review
# SCM_SKIP_TITLE_PATTERN=[skip-review]
# Optional: auto-submit APPROVE / REQUEST_CHANGES from aggregated open high/medium (this run + SCM)
# See README "Auto review decision" for per-provider unresolved/thread/task semantics.
# SCM_REVIEW_DECISION_ENABLED=false
# SCM_REVIEW_DECISION_HIGH_THRESHOLD=1
# SCM_REVIEW_DECISION_MEDIUM_THRESHOLD=3
# Bitbucket Server/DC only (participant API username slug for auto review decisions):
# SCM_BITBUCKET_SERVER_USER_SLUG=

# -----------------------------------------------------------------------------
# Optional: context-aware review (linked GitHub Issues, Jira, Confluence)
# See docs/CONTEXT-AWARE-USER-GUIDE.md, docs/CONTEXT-AWARE-DEVELOPER-GUIDE.md, and docs/PGVECTOR-SCHEMA.md
# -----------------------------------------------------------------------------
# CONTEXT_AWARE_REVIEW_ENABLED=false
# CONTEXT_AWARE_REVIEW_DB_URL=postgresql://user:pass@host:5432/dbname
# CONTEXT_GITHUB_ISSUES_ENABLED=true
# CONTEXT_ATLASSIAN_EMAIL=you@yourcompany.com
# CONTEXT_ATLASSIAN_TOKEN=
# CONTEXT_JIRA_ENABLED=false
# CONTEXT_ATLASSIAN_URL=https://yourcompany.atlassian.net
# CONTEXT_CONFLUENCE_ENABLED=true
# CONTEXT_MAX_BYTES=20000
# CONTEXT_DISTILLED_MAX_TOKENS=4000
# CONTEXT_EMBEDDING_MODEL=text-embedding-3-small
# CONTEXT_EMBEDDING_DIMENSIONS=1536
# RAG embeddings use litellm; the chosen model must match your LLM_* credentials (e.g. OpenAI key for text-embedding-3-small).
# For GitHub Issues when SCM is not GitHub: CONTEXT_GITHUB_TOKEN=  CONTEXT_GITHUB_API_URL=
# pip install -e ".[context]"  # adds psycopg for PostgreSQL/pgvector
# CODE_REVIEW_INCLUDE_COMMIT_MESSAGES_IN_PROMPT=true
# CODE_REVIEW_REVIEW_VISIBLE_LINES=false

# LLM (single key; provider chosen via LLM_PROVIDER)
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
LLM_API_KEY=your_llm_api_key_here
LLM_CONTEXT_WINDOW=128000
LLM_MAX_OUTPUT_TOKENS=4096
# OLLAMA_API_BASE=http://localhost:11434  # only for LLM_PROVIDER=ollama

# -----------------------------------------------------------------------------
# E2E UI (Playwright standalone scripts: python -m e2e_ui.run_single_scm / run_multi_scm)
# Used only when running the Jenkins setup automation scripts. See docs/E2E-UI-JENKINS.md.
# -----------------------------------------------------------------------------
# Jenkins instance the scripts drive (base URL, no trailing slash).
# Default if unset: http://localhost:8080 (local dev only).
# JENKINS_URL=http://localhost:8080

# Jenkins login. Required for both run_single_scm and run_multi_scm.
# Use the same user/password you use in the browser (e.g. admin for Quick Start Docker).
# JENKINS_USERNAME=admin
# JENKINS_PASSWORD=admin

# Repo URL for "Pipeline script from SCM". Required for both scripts.
# Set to your fork or the repo Jenkins will clone (e.g. https://github.com/your-org/code-review.git).
# Use HTTPS in production; avoid hardcoding http:// in scripts.
# E2E_UI_REPO_URL=https://github.com/your-org/code-review.git

# Branch to use for Pipeline script from SCM. Optional; default: main.
# E2E_UI_BRANCH=main

# Required only for run_single_scm: SCM_PROVIDER and SCM_URL are written to Jenkins global env.
# SCM_PROVIDER must match the scripted E2E flow (gitea, github, gitlab, bitbucket_server). Use the same values as above.
# Prefer https:// for SCM_URL in production; http is acceptable only for local/dev (e.g. Docker).
# SCM_PROVIDER=gitea
# SCM_URL=https://gitea.example.com

# Run browser in headed mode (visible). Optional; default is headless.
# E2E_UI_HEADED=1
