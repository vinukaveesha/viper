# Log level for the CLI: DEBUG, INFO, WARNING (default), ERROR. Set INFO to see progress.
# CODE_REVIEW_LOG_LEVEL=INFO

# SCM (Gitea, GitLab, Bitbucket)
SCM_PROVIDER=gitea
SCM_URL=http://localhost:3000
SCM_TOKEN=your_api_token_here
# Optional: skip review when PR has this label or title contains this substring
# SCM_SKIP_LABEL=skip-review
# SCM_SKIP_TITLE_PATTERN=[skip-review]

# LLM
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
LLM_CONTEXT_WINDOW=128000
LLM_MAX_OUTPUT_TOKENS=4096

# Provider-specific API keys
GOOGLE_API_KEY=your_google_api_key
# OPENAI_API_KEY=...
# ANTHROPIC_API_KEY=...
# OLLAMA_API_BASE=http://localhost:11434

# -----------------------------------------------------------------------------
# E2E UI (Playwright standalone scripts: python -m e2e_ui.run_single_scm / run_multi_scm)
# Used only when running the Jenkins setup automation scripts. See docs/E2E-UI-JENKINS.md.
# -----------------------------------------------------------------------------
# Jenkins instance the scripts drive (base URL, no trailing slash).
# Default if unset: http://localhost:8080 (local dev only).
# JENKINS_URL=http://localhost:8080

# Jenkins login. Required for both run_single_scm and run_multi_scm.
# Use the same user/password you use in the browser (e.g. admin for Quick Start Docker).
# JENKINS_USERNAME=admin
# JENKINS_PASSWORD=admin

# Repo URL for "Pipeline script from SCM". Required for both scripts.
# Set to your fork or the repo Jenkins will clone (e.g. https://github.com/your-org/code-review.git).
# Use HTTPS in production; avoid hardcoding http:// in scripts.
# E2E_UI_REPO_URL=https://github.com/your-org/code-review.git

# Branch to use for Pipeline script from SCM. Optional; default: main.
# E2E_UI_BRANCH=main

# Required only for run_single_scm: SCM_PROVIDER and SCM_URL are written to Jenkins global env.
# SCM_PROVIDER must match the agent (gitea, github, gitlab, bitbucket). Use the same values as above.
# Prefer https:// for SCM_URL in production; http is acceptable only for local/dev (e.g. Docker).
# SCM_PROVIDER=gitea
# SCM_URL=https://gitea.example.com

# Run browser in headed mode (visible). Optional; default is headless.
# E2E_UI_HEADED=1
